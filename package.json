{
  "name": "tab-nuke",
  "version": "1.0.0",
  "private": true,
  "description": "Smart tab manager that tames your browser. Auto-suspend, session save, focus mode, memory dashboard.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package:chrome": "node scripts/package.js chrome",
    "package:firefox": "node scripts/package.js firefox",
    "package:edge": "node scripts/package.js edge",
    "ci": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm audit --audit-level=high || true && pnpm test:coverage && pnpm build",
    "validate": "pnpm ci"
  },
  "dependencies": {
    "dexie": "^4.0.11",
    "fuse.js": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-security": "^3.0.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
"pnpm": {
    "overrides": {
        "@crxjs/vite-plugin>rollup": "^4.60.2"
    }
},
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.4"
}
